# Environment Variables untuk API Keys
# PENTING: Jangan commit file .env ke Git!
# Copy file ini menjadi .env dan isi dengan API key Anda

# Google Gemini API Key
# Dapatkan di: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key
# Dapatkan di: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (opsional)
# Dapatkan di: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
